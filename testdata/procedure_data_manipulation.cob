IDENTIFICATION DIVISION.
PROGRAM-ID. DATADEMO.
PROCEDURE DIVISION.
    INITIALIZE WS-RECORD.
    INITIALIZE WS-NAME WS-TOTAL.
    SET WS-IDX TO 1.
    SET WS-IDX UP BY 1.
    SET WS-IDX DOWN BY 2.
    SET WS-DONE TO TRUE.
    STRING WS-FIRST WS-LAST DELIMITED BY SIZE
        WS-SUFFIX DELIMITED BY ", " INTO WS-FULL
        WITH POINTER WS-PTR
        ON OVERFLOW DISPLAY "overflow"
        NOT ON OVERFLOW DISPLAY "ok"
        END-STRING.
    UNSTRING WS-FULL DELIMITED BY ALL " " OR ","
        INTO WS-A DELIMITER IN WS-D COUNT IN WS-C
        WS-B
        WITH POINTER WS-PTR TALLYING IN WS-TALLY
        ON OVERFLOW DISPLAY "of"
        END-UNSTRING.
    INSPECT WS-TEXT TALLYING WS-COUNT FOR ALL "A" BEFORE INITIAL "Z"
        WS-CHARS FOR CHARACTERS AFTER INITIAL " ".
    INSPECT WS-TEXT REPLACING LEADING "0" BY " " FIRST "X" BY "Y"
        CHARACTERS BY "*" AFTER INITIAL "(".
    SEARCH ALL WS-TABLE AT END DISPLAY "not found"
        WHEN WS-KEY(WS-IDX) = WS-TARGET
            DISPLAY "found"
        END-SEARCH.
    SEARCH WS-TABLE VARYING WS-IDX
        WHEN WS-FLAG(WS-IDX) = ZERO
            SET WS-DONE TO TRUE
        WHEN WS-FLAG(WS-IDX) = 1
            NEXT SENTENCE
        END-SEARCH.
    INSPECT WS-TEXT CONVERTING "abc" TO "ABC" AFTER INITIAL " ".
    SET WS-PTR TO ADDRESS OF WS-RECORD.
    SET ADDRESS OF WS-RECORD TO WS-PTR.
    SET WS-SWITCH TO ON.
    SET WS-SWITCH TO OFF.
    INITIALIZE WS-RECORD REPLACING NUMERIC BY ZERO ALPHANUMERIC DATA BY SPACE.
    INITIALIZE WS-RECORD WITH FILLER ALL TO VALUE.
    INITIALIZE WS-RECORD ALPHANUMERIC TO VALUE REPLACING NUMERIC BY ZERO DEFAULT.
    SEARCH ALL WS-TABLE
        WHEN WS-KEY(WS-IDX) = WS-TARGET AND WS-VALID
            DISPLAY "found"
        END-SEARCH.
    STOP RUN.
