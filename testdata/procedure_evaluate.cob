IDENTIFICATION DIVISION.
PROGRAM-ID. EVALDEMO.
PROCEDURE DIVISION.
    EVALUATE WS-CODE
    WHEN 1
        DISPLAY "one"
    WHEN 2 THROUGH 5
        MOVE 1 TO WS-RESULT
    WHEN OTHER
        DISPLAY "many"
    END-EVALUATE.
    EVALUATE TRUE
    WHEN WS-A > WS-B
        MOVE WS-A TO WS-MAX
    WHEN WS-A = WS-B AND WS-C < 10
        CONTINUE
    WHEN NOT WS-D IS NUMERIC
        DISPLAY "bad"
    END-EVALUATE.
    EVALUATE WS-X ALSO WS-Y
    WHEN 1 ALSO ANY
        DISPLAY "first"
    WHEN ANY ALSO 2 THRU 9
        DISPLAY "second"
    WHEN OTHER
        CONTINUE
    END-EVALUATE.
    EVALUATE WS-FLAG
    WHEN "Y" DISPLAY "yes"
    WHEN "N" DISPLAY "no"
    END-EVALUATE.
    STOP RUN.
