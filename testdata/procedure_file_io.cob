IDENTIFICATION DIVISION.
PROGRAM-ID. FILEIO.
ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT CUST-FILE ASSIGN TO "cust.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS CUST-ID.
    SELECT LOG-FILE ASSIGN TO "log.txt"
        ORGANIZATION IS LINE SEQUENTIAL.
    SELECT REPORT-FILE ASSIGN TO "report.txt".
DATA DIVISION.
FILE SECTION.
FD CUST-FILE.
01 CUST-RECORD.
    05 CUST-ID PIC 9(5).
    05 CUST-NAME PIC X(20).
FD LOG-FILE.
01 LOG-RECORD PIC X(80).
FD REPORT-FILE.
01 REPORT-LINE PIC X(132).
WORKING-STORAGE SECTION.
01 WS-CUST PIC X(25).
01 WS-LINE PIC X(132).
PROCEDURE DIVISION.
    OPEN INPUT CUST-FILE REVERSED OUTPUT REPORT-FILE I-O LOG-FILE.
    OPEN EXTEND LOG-FILE WITH NO REWIND.
    START CUST-FILE KEY >= CUST-ID
        INVALID KEY DISPLAY "none"
    END-START.
    READ CUST-FILE NEXT RECORD INTO WS-CUST
        AT END DISPLAY "eof"
        NOT AT END DISPLAY WS-CUST
    END-READ.
    READ CUST-FILE KEY IS CUST-ID
        INVALID KEY DISPLAY "bad key".
    WRITE REPORT-LINE FROM WS-LINE AFTER ADVANCING 2 LINES
        AT END-OF-PAGE DISPLAY "page"
    END-WRITE.
    WRITE CUST-RECORD FROM WS-CUST
        INVALID KEY DISPLAY "dup"
    END-WRITE.
    REWRITE CUST-RECORD FROM WS-CUST
        INVALID KEY DISPLAY "missing"
    END-REWRITE.
    DELETE CUST-FILE RECORD
        INVALID KEY DISPLAY "nodel"
    END-DELETE.
    CLOSE CUST-FILE WITH LOCK REPORT-FILE LOG-FILE FOR REMOVAL.
    STOP RUN.
